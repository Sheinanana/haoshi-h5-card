# H5 名片页后端环境变量示例
# 复制本文件为 .env 并填入真实值，或在部署平台设置环境变量

# 服务端口（可选，默认 3000）
PORT=3000

# 客户留言数据文件路径（可选，默认 data/submissions.json）
SUBMISSIONS_FILE=./data/submissions.json

# 跨域白名单，多个用英文逗号分隔；留空则不限制
# 示例：ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=

# 通知 Webhook 地址（推荐配置企业微信群机器人）
# 企业微信群机器人：登录企业微信 PC 端 -> 群聊 -> 添加群机器人 -> 复制 Webhook 地址
NOTIFY_WEBHOOK_URL=

# Webhook 类型：generic（通用 JSON） | wecom（企业微信） | feishu（飞书）
NOTIFY_WEBHOOK_TYPE=wecom
